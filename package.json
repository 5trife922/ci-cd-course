{
  "name": "sqlite-todo",
  "version": "1.0.0",
  "private": true,
  "description": "Простой todo с SQLite и миграциями",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "lint": "node ./node_modules/eslint/bin/eslint.js .",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "node ./node_modules/jest/bin/jest.js --testPathIgnorePatterns=test/integration",
    "test:integration": "node ./node_modules/jest/bin/jest.js test/integration",
    "test:e2e": "node ./node_modules/@playwright/test/cli.js test",
    "test:e2e:ui": "node ./node_modules/@playwright/test/cli.js test --ui",
    "test:watch": "node ./node_modules/jest/bin/jest.js --watch"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "better-sqlite3": "^11.6.0",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "eslint": "^8.57.1",
    "eslint-config-google": "^0.14.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  }
}
